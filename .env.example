# ─────────────────────────────────────────────────────────────────────────────
# Orion IDE — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in all values.
# Each service reads only the variables it needs.
# ─────────────────────────────────────────────────────────────────────────────

# ── SHARED ──────────────────────────────────────────────────────────────────
NODE_ENV=development
REDIS_URL=redis://redis:6379

# ── AUTH SERVICE (Port 3001) ────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback

# JWT signing secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-jwt-secret-here-min-64-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here-min-64-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── DRIVE SERVICE (Port 3002) ──────────────────────────────────────────────
# Internal secret for service-to-service calls (agent-service → drive-service)
DRIVE_SERVICE_SECRET=your-internal-drive-service-secret

# ── EXECUTION SERVICE (Port 3004) ──────────────────────────────────────────
# URL of the self-hosted Piston code execution sandbox
PISTON_API_URL=http://piston:2000

# ── AGENT SERVICE (Port 3005) ──────────────────────────────────────────────
# Groq API key — free tier at https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# OpenRouter API key — free tier at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key

# Internal service URLs (Docker service names resolve within the network)
DRIVE_SERVICE_URL=http://drive-service:3002
EXECUTION_SERVICE_URL=http://execution-service:3004
NOTIFICATION_SERVICE_URL=http://notification-service:3006

# ── API GATEWAY (Port 3000) ────────────────────────────────────────────────
# Internal URLs for routing requests to backend services
AUTH_SERVICE_URL=http://auth-service:3001
# DRIVE_SERVICE_URL is defined above (shared with agent-service)
EDITOR_SERVICE_URL=http://editor-service:3003
# EXECUTION_SERVICE_URL is defined above (shared with agent-service)
AGENT_SERVICE_URL=http://agent-service:3005
# NOTIFICATION_SERVICE_URL is defined above (shared with agent-service)

# ── FRONTEND ───────────────────────────────────────────────────────────────
# Base URL for API calls from the React app (goes through nginx → API Gateway)
REACT_APP_API_URL=http://localhost/api
